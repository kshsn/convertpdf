# App
NEXT_PUBLIC_APP_URL=https://convertpdf.proailabs.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/convertpdf

# NextAuth
NEXTAUTH_URL=https://convertpdf.proailabs.com
NEXTAUTH_SECRET=your-secret-here

# Paddle
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your-paddle-client-token
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
NEXT_PUBLIC_PADDLE_PRO_PRICE_ID=your-pro-price-id
NEXT_PUBLIC_PADDLE_PRO_ANNUAL_PRICE_ID=your-pro-annual-price-id
NEXT_PUBLIC_PADDLE_BIZ_PRICE_ID=your-biz-price-id

# Resend (email)
RESEND_API_KEY=your-resend-api-key

# Google (AdSense + Analytics)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXX
